<script>
function switchTab(id,e){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.pane').forEach(p=>p.classList.remove('active'));
  e.target.classList.add('active');
  document.getElementById('pane-'+id).classList.add('active');
}
function fmt(n){return Math.round(n).toLocaleString('ja-JP')+'円';}
function g(id){return parseFloat(document.getElementById(id).value)||0;}
function syncPU(v){document.getElementById('price-up').value=v;calcSim();}
function syncPUn(v){document.getElementById('price-up-r').value=Math.min(30000,Math.max(0,v));calcSim();}
function calcSim(){
  const vid=g('vid-n')*g('vid-p');
  const priceUp=g('price-up')*18;
  const alumni=g('alumni-n')*g('alumni-p');
  const corp=g('corp-n')*g('corp-p');
  const tools=g('tools-sales')*(g('tools-margin')/100);
  const total=vid+priceUp+alumni+corp+tools;
  document.getElementById('s-vid').textContent=fmt(vid);
  document.getElementById('s-price').textContent=fmt(priceUp);
  document.getElementById('s-alumni').textContent=fmt(alumni);
  document.getElementById('s-corp').textContent=fmt(corp);
  document.getElementById('s-tools').textContent=fmt(tools);
  document.getElementById('s-total').textContent=fmt(total);
  document.getElementById('s-annual').textContent=fmt(total*12);
}
calcSim();
</script>
